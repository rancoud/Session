{
    "name": "rancoud/session",
    "description": "Session package",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sebastien Rancoud",
            "email": "contact@rancoud.com"
        }
    ],
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Rancoud\\Session\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests"
        }
    },
    "require": {
        "php": ">=8.4.0",
        "ext-openssl": "*",
        "ext-session": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "3.95.1",
        "phpunit/phpunit": "12.5.22",
        "predis/predis": "3.4.2",
        "rancoud/database": "7.0.3"
    },
    "scripts": {
        "ci": [
            "@lint",
            "@test"
        ],
        "lint": [
            "php-cs-fixer fix -vvv"
        ],
        "test": [
            "phpunit --colors --display-all-issues --coverage-html ./coverage --coverage-clover coverage/clover.xml"
        ]
    }
}
